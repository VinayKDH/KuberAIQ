# GCP Cloud Run deploy — copy to .env.gcp (never commit .env.gcp).
# Used by: scripts/deploy-gcp.sh, scripts/provision-gcp-cloudsql.sh
#
# Production auth checklist:
#   USE_MOCK_AUTH=false
#   NEXT_PUBLIC_USE_MOCK_AUTH=false (set via deploy build-arg from USE_MOCK_AUTH)
#   Configure at least one OAuth provider (Google and/or Microsoft Entra)
#   JWT_SECRET — strong random string (required)
#   ADMIN_API_KEY — platform admin portal (server-side only)

GCP_PROJECT_ID=bharatfreight-os-prod
GCP_REGION=asia-south1
GCP_CLOUDSQL_INSTANCE=bf-postgres
GCP_CLOUDSQL_CONNECTION_NAME=bharatfreight-os-prod:asia-south1:bf-postgres
GCP_DB_USER=kuberaiq
GCP_DB_PASSWORD=
KUBERAIQ_DB_NAME=kuberaiq

# Filled by provision-gcp-cloudsql.sh or manually:
# postgresql+asyncpg://USER:PASS@localhost/kuberaiq?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=

GCP_API_SERVICE=kuberaiq-api-gcp
GCP_WEB_SERVICE=kuberaiq-web-gcp
GCP_ARTIFACT_REPO=kuberaiq
# Optional — defaults to timestamp if unset
# GCP_IMAGE_TAG=20260623120000

ENVIRONMENT=production

# App secrets (can copy from .env.prod)
JWT_SECRET=

# --- Production mode (disable demo auth) ---
USE_MOCK_AUTH=false
USE_MOCK_BILLING=false
USE_MOCK_LLM=true
USE_MOCK_BLOB=true
USE_MOCK_WHATSAPP=true

# Google OAuth — required for Google sign-in (at least one provider when USE_MOCK_AUTH=false)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://www.kuberaiq.com/auth/callback

# Microsoft Entra ID — optional second sign-in provider
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# ENTRA_REDIRECT_URI=https://www.kuberaiq.com/auth/callback

# Frontend OAuth build args (passed by deploy-gcp.sh)
NEXT_PUBLIC_OAUTH_COOKIE_DOMAIN=.kuberaiq.com
NEXT_PUBLIC_APEX_DOMAIN=kuberaiq.com
# CORS_ORIGINS=["https://www.kuberaiq.com","https://kuberaiq.com"]

# Razorpay — required when USE_MOCK_BILLING=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
SUBSCRIPTION_PLAN_AMOUNT_PAISE=99900
# Webhook URL in Razorpay Dashboard: https://api.kuberaiq.com/api/v1/billing/webhooks/razorpay

# Platform admin portal (server-side only — never expose in NEXT_PUBLIC_*)
ADMIN_API_KEY=
ADMIN_EMAIL=admin@kuberaiq.com

# WhatsApp Cloud API — set USE_MOCK_WHATSAPP=false when creds are present
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_VERIFY_TOKEN=kuberaiq-verify
# WHATSAPP_APP_SECRET=

# Azure OpenAI — set USE_MOCK_LLM=false when configured
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure Blob — set USE_MOCK_BLOB=false when configured
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=invoices

# Custom domains — set after Hostinger DNS + GCP domain mappings (see docs/gcp-custom-domains.md)
PUBLIC_WEB_DOMAIN=www.kuberaiq.com
PUBLIC_API_DOMAIN=api.kuberaiq.com
PUBLIC_APEX_DOMAIN=kuberaiq.com
# Uncomment after DNS cutover (deploy-gcp.sh uses PUBLIC_WEB_URL for NEXT_PUBLIC_WEB_URL build arg)
# PUBLIC_WEB_URL=https://www.kuberaiq.com
# PUBLIC_API_URL=https://api.kuberaiq.com
# GCP_WEB_ORIGIN=https://kuberaiq-web-gcp-zu3hk22ncq-el.a.run.app
# GCP_API_ORIGIN=https://kuberaiq-api-gcp-zu3hk22ncq-el.a.run.app
# Setup: ./scripts/setup-gcp-domains.sh --dns-only  then  ./scripts/setup-gcp-domains.sh
# OAuth redirect URIs to register: https://www.kuberaiq.com/auth/callback + Cloud Run web URL/auth/callback

# AI token budget (soft cap per company per month)
# AI_SOFT_TOKEN_BUDGET_MONTHLY=200000
