# GCP Cloud Run deploy — copy to .env.gcp (never commit .env.gcp).
# Used by: scripts/deploy-gcp.sh, scripts/provision-gcp-cloudsql.sh

GCP_PROJECT_ID=bharatfreight-os-prod
GCP_REGION=asia-south1
GCP_CLOUDSQL_INSTANCE=bf-postgres
GCP_CLOUDSQL_CONNECTION_NAME=bharatfreight-os-prod:asia-south1:bf-postgres
GCP_DB_USER=kuberaiq
GCP_DB_PASSWORD=
KUBERAIQ_DB_NAME=kuberaiq

# Filled by provision-gcp-cloudsql.sh or manually:
# postgresql+asyncpg://USER:PASS@localhost/kuberaiq?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=

GCP_API_SERVICE=kuberaiq-api-gcp
GCP_WEB_SERVICE=kuberaiq-web-gcp
GCP_ARTIFACT_REPO=kuberaiq

# App secrets (can copy from .env.prod)
JWT_SECRET=
USE_MOCK_AUTH=true
USE_MOCK_LLM=true
USE_MOCK_BLOB=true
USE_MOCK_WHATSAPP=true
USE_MOCK_BILLING=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://www.kuberaiq.com/auth/callback

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
SUBSCRIPTION_PLAN_AMOUNT_PAISE=99900
