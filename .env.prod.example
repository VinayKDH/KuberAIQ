# KuberAIQ production Azure deploy — copy to .env.prod (never commit .env.prod).
# Used by: scripts/deploy-prod.sh, scripts/setup-kuberaiq-domains.sh

AZURE_RESOURCE_GROUP=rg-kuberaiq-prod
# Filled by scripts/deploy-azure.sh after first provision:
AZURE_ACR=
AZURE_API_APP_NAME=kuberaiq-api-prod
AZURE_WEB_APP_NAME=kuberaiq-web-prod
AZURE_WEB_HOSTNAME=kuberaiq-web-prod.azurewebsites.net
AZURE_API_HOSTNAME=kuberaiq-api-prod.azurewebsites.net

AZURE_POSTGRES_FQDN=
POSTGRES_ADMIN_LOGIN=kuberaiqadmin
POSTGRES_ADMIN_PASSWORD=

# Production custom domains only
PUBLIC_WEB_URL=https://www.kuberaiq.com
PUBLIC_API_URL=https://api.kuberaiq.com
PUBLIC_WEB_DOMAIN=www.kuberaiq.com
PUBLIC_API_DOMAIN=api.kuberaiq.com
PUBLIC_APEX_DOMAIN=kuberaiq.com

ENVIRONMENT=production
JWT_SECRET=
USE_MOCK_AUTH=false
USE_MOCK_LLM=true
USE_MOCK_BLOB=false
USE_MOCK_WHATSAPP=true
USE_MOCK_BILLING=false

# Razorpay — required when USE_MOCK_BILLING=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
SUBSCRIPTION_PLAN_AMOUNT_PAISE=99900
# Webhook URL in Razorpay Dashboard: https://api.kuberaiq.com/api/v1/billing/webhooks/razorpay
# Event: payment.captured

# Frontend build (deploy-prod.sh): NEXT_PUBLIC_USE_MOCK_BILLING=false

CORS_ORIGINS=["https://www.kuberaiq.com","https://kuberaiq.com","https://api.kuberaiq.com"]

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://www.kuberaiq.com/auth/callback

NEXT_PUBLIC_OAUTH_COOKIE_DOMAIN=.kuberaiq.com
NEXT_PUBLIC_APEX_DOMAIN=kuberaiq.com

# Azure OpenAI — required when USE_MOCK_LLM=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure Blob — required when USE_MOCK_BLOB=false
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=invoices

# WhatsApp Cloud API — required when USE_MOCK_WHATSAPP=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=kuberaiq-verify
WHATSAPP_APP_SECRET=
# Meta webhook URL: https://api.kuberaiq.com/api/v1/webhooks/whatsapp
# Templates: payment_reminder_en, payment_reminder_hi (utility, body {{1}})
