# KuberAIQ production Azure deploy — copy to .env.prod (never commit .env.prod).
# Used by: scripts/deploy-prod.sh, scripts/setup-kuberaiq-domains.sh

AZURE_RESOURCE_GROUP=rg-kuberaiq-prod
# Filled by scripts/deploy-azure.sh after first provision:
AZURE_ACR=
AZURE_API_APP_NAME=kuberaiq-api-prod
AZURE_WEB_APP_NAME=kuberaiq-web-prod
AZURE_WEB_HOSTNAME=kuberaiq-web-prod.azurewebsites.net
AZURE_API_HOSTNAME=kuberaiq-api-prod.azurewebsites.net

AZURE_POSTGRES_FQDN=
POSTGRES_ADMIN_LOGIN=kuberaiqadmin
POSTGRES_ADMIN_PASSWORD=

# Production custom domains only
PUBLIC_WEB_URL=https://www.kuberaiq.com
PUBLIC_API_URL=https://api.kuberaiq.com
PUBLIC_WEB_DOMAIN=www.kuberaiq.com
PUBLIC_API_DOMAIN=api.kuberaiq.com
PUBLIC_APEX_DOMAIN=kuberaiq.com

ENVIRONMENT=production
JWT_SECRET=
USE_MOCK_AUTH=false
USE_MOCK_LLM=true
USE_MOCK_BLOB=false
USE_MOCK_WHATSAPP=true
USE_MOCK_BILLING=true

CORS_ORIGINS=["https://www.kuberaiq.com","https://kuberaiq.com","https://api.kuberaiq.com"]

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://www.kuberaiq.com/auth/callback

NEXT_PUBLIC_OAUTH_COOKIE_DOMAIN=.kuberaiq.com
NEXT_PUBLIC_APEX_DOMAIN=kuberaiq.com
