# Environment
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=INFO

# Database (async SQLAlchemy URL)
DATABASE_URL=postgresql+asyncpg://vyaparai:vyaparai@localhost:5432/vyaparai

# Auth / JWT
JWT_SECRET=dev-only-change-me
JWT_ALGORITHM=HS256

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Mock toggles (true for local dev)
USE_MOCK_LLM=true
USE_MOCK_BLOB=true
USE_MOCK_WHATSAPP=true
USE_MOCK_AUTH=true

# Azure OpenAI (when USE_MOCK_LLM=false)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure Blob (when USE_MOCK_BLOB=false)
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=invoices
LOCAL_BLOB_DIR=local_blob_storage

# WhatsApp Cloud API (when USE_MOCK_WHATSAPP=false)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=vyaparai-verify
WHATSAPP_APP_SECRET=

# Entra ID (when USE_MOCK_AUTH=false)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
