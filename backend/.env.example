# Environment
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=INFO

# Database (async SQLAlchemy URL)
DATABASE_URL=postgresql+asyncpg://kuberaiq:kuberaiq@localhost:5432/kuberaiq

# Auth / JWT
JWT_SECRET=dev-only-change-me
JWT_ALGORITHM=HS256

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Mock toggles (true for local dev)
USE_MOCK_LLM=true
USE_MOCK_BLOB=true
USE_MOCK_WHATSAPP=true
USE_MOCK_AUTH=true
USE_MOCK_BILLING=true

# Razorpay (when USE_MOCK_BILLING=false)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
SUBSCRIPTION_PLAN_AMOUNT_PAISE=99900

# Azure OpenAI (when USE_MOCK_LLM=false)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure Blob (when USE_MOCK_BLOB=false)
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=invoices
# Production alias (also accepted): AZURE_STORAGE_CONNECTION_STRING, AZURE_STORAGE_CONTAINER
LOCAL_BLOB_DIR=local_blob_storage

# WhatsApp Cloud API (when USE_MOCK_WHATSAPP=false)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=kuberaiq-verify
WHATSAPP_APP_SECRET=

# Entra ID (when USE_MOCK_AUTH=false)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# Google OAuth (when USE_MOCK_AUTH=false)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
