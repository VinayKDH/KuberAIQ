{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.39.26.7824",
      "templateHash": "2828253127490615396"
    }
  },
  "parameters": {
    "environmentName": {
      "type": "string",
      "defaultValue": "dev",
      "metadata": {
        "description": "Environment name (dev, staging, prod)"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for compute, storage, and networking"
      }
    },
    "postgresLocation": {
      "type": "string",
      "defaultValue": "centralindia",
      "metadata": {
        "description": "Azure region for PostgreSQL (may differ when subscription has regional quotas)"
      }
    },
    "nameSuffix": {
      "type": "string",
      "defaultValue": "[uniqueString(resourceGroup().id)]",
      "metadata": {
        "description": "Short unique suffix for globally unique resource names"
      }
    },
    "postgresAdminLogin": {
      "type": "securestring",
      "metadata": {
        "description": "PostgreSQL admin login"
      }
    },
    "postgresAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "PostgreSQL admin password"
      }
    },
    "jwtSecret": {
      "type": "securestring",
      "metadata": {
        "description": "JWT signing secret"
      }
    },
    "openaiApiKey": {
      "type": "securestring",
      "metadata": {
        "description": "Azure OpenAI API key (set via deploy script or CI secret)"
      }
    },
    "whatsappVerifyToken": {
      "type": "string",
      "defaultValue": "kuberaiq-verify",
      "metadata": {
        "description": "WhatsApp verify token"
      }
    },
    "googleClientId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Google OAuth client ID (Web application)"
      }
    },
    "googleClientSecret": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Google OAuth client secret"
      }
    },
    "entraTenantId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Microsoft Entra tenant ID"
      }
    },
    "entraClientId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Microsoft Entra application client ID"
      }
    },
    "entraClientSecret": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Microsoft Entra client secret"
      }
    },
    "webAppHostName": {
      "type": "string",
      "defaultValue": "[if(equals(parameters('environmentName'), 'prod'), 'kuberaiq-web-prod', format('kuberaiq-web-{0}', parameters('environmentName')))]",
      "metadata": {
        "description": "Public hostname for the Next.js web app (must be globally unique)"
      }
    },
    "apiAppHostName": {
      "type": "string",
      "defaultValue": "[if(equals(parameters('environmentName'), 'prod'), 'kuberaiq-api-prod', format('kuberaiq-api-{0}', parameters('environmentName')))]",
      "metadata": {
        "description": "Public hostname for the FastAPI app (must be globally unique)"
      }
    }
  },
  "variables": {
    "appServicePlanName": "[format('asp-kuberaiq-{0}', parameters('environmentName'))]",
    "postgresDbName": "kuberaiq",
    "blobContainerName": "invoices",
    "apiAppName": "[parameters('apiAppHostName')]",
    "webAppName": "[parameters('webAppHostName')]",
    "postgresServerName": "[format('kuberaiq-pg-{0}', parameters('nameSuffix'))]",
    "storageAccountName": "[format('kuberaiq{0}', parameters('nameSuffix'))]",
    "keyVaultName": "[format('kv-kuberaiq-{0}', take(parameters('nameSuffix'), 8))]",
    "acrName": "[format('kuberaiq{0}', take(parameters('nameSuffix'), 10))]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('appServicePlanName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[if(equals(parameters('environmentName'), 'prod'), 'P1v3', 'B1')]",
        "tier": "[if(equals(parameters('environmentName'), 'prod'), 'PremiumV3', 'Basic')]",
        "capacity": "[if(equals(parameters('environmentName'), 'prod'), 2, 1)]"
      },
      "kind": "linux",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-07-01",
      "name": "[variables('acrName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[if(equals(parameters('environmentName'), 'prod'), 'Standard', 'Basic')]"
      },
      "properties": {
        "adminUserEnabled": false,
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[variables('keyVaultName')]",
      "location": "[parameters('location')]",
      "properties": {
        "tenantId": "[subscription().tenantId]",
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "enableRbacAuthorization": true,
        "enableSoftDelete": true,
        "softDeleteRetentionInDays": 90,
        "enablePurgeProtection": true
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('keyVaultName'), 'database-url')]",
      "properties": {
        "value": "[format('postgresql+asyncpg://{0}:{1}@{2}:5432/{3}?ssl=require', parameters('postgresAdminLogin'), parameters('postgresAdminPassword'), reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName')), '2023-12-01-preview').fullyQualifiedDomainName, variables('postgresDbName'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]",
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('keyVaultName'), 'jwt-secret')]",
      "properties": {
        "value": "[parameters('jwtSecret')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('keyVaultName'), 'blob-connection-string')]",
      "properties": {
        "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};AccountKey={1};EndpointSuffix={2}', variables('storageAccountName'), listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').keys[0].value, environment().suffixes.storage)]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('keyVaultName'), 'openai-api-key')]",
      "properties": {
        "value": "[parameters('openaiApiKey')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[if(equals(parameters('environmentName'), 'prod'), 'Standard_GRS', 'Standard_LRS')]"
      },
      "kind": "StorageV2",
      "properties": {
        "accessTier": "Hot",
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": true,
        "allowBlobPublicAccess": false
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', variables('storageAccountName'), 'default')]",
      "properties": {
        "deleteRetentionPolicy": {
          "enabled": true,
          "days": 30
        },
        "containerDeleteRetentionPolicy": {
          "enabled": true,
          "days": 30
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}/{2}', variables('storageAccountName'), 'default', variables('blobContainerName'))]",
      "properties": {
        "publicAccess": "None"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('storageAccountName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers",
      "apiVersion": "2023-12-01-preview",
      "name": "[variables('postgresServerName')]",
      "location": "[parameters('postgresLocation')]",
      "sku": {
        "name": "[if(equals(parameters('environmentName'), 'prod'), 'Standard_D2s_v3', 'Standard_B1ms')]",
        "tier": "[if(equals(parameters('environmentName'), 'prod'), 'GeneralPurpose', 'Burstable')]"
      },
      "properties": {
        "version": "16",
        "administratorLogin": "[parameters('postgresAdminLogin')]",
        "administratorLoginPassword": "[parameters('postgresAdminPassword')]",
        "storage": {
          "storageSizeGB": "[if(equals(parameters('environmentName'), 'prod'), 128, 32)]"
        },
        "backup": {
          "backupRetentionDays": "[if(equals(parameters('environmentName'), 'prod'), 35, 7)]",
          "geoRedundantBackup": "[if(equals(parameters('environmentName'), 'prod'), 'Enabled', 'Disabled')]"
        },
        "highAvailability": {
          "mode": "Disabled"
        }
      }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2023-12-01-preview",
      "name": "[format('{0}/{1}', variables('postgresServerName'), variables('postgresDbName'))]",
      "properties": {
        "charset": "UTF8",
        "collation": "en_US.utf8"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]"
      ]
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/firewallRules",
      "apiVersion": "2023-12-01-preview",
      "name": "[format('{0}/{1}', variables('postgresServerName'), 'AllowAzureServices')]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]"
      ]
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/configurations",
      "apiVersion": "2023-12-01-preview",
      "name": "[format('{0}/{1}', variables('postgresServerName'), 'azure.extensions')]",
      "properties": {
        "value": "pgcrypto",
        "source": "user-override"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName'))]"
      ]
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[format('law-kuberaiq-{0}', parameters('environmentName'))]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[format('appi-kuberaiq-{0}', parameters('environmentName'))]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', format('law-kuberaiq-{0}', parameters('environmentName')))]",
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery": "Enabled"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', format('law-kuberaiq-{0}', parameters('environmentName')))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[variables('apiAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "[format('DOCKER|{0}/kuberaiq-api:latest', reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').loginServer)]",
          "acrUseManagedIdentityCreds": true,
          "alwaysOn": "[not(equals(parameters('environmentName'), 'dev'))]",
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "appSettings": [
            {
              "name": "ENVIRONMENT",
              "value": "[parameters('environmentName')]"
            },
            {
              "name": "USE_MOCK_LLM",
              "value": "[if(equals(parameters('environmentName'), 'prod'), 'false', 'true')]"
            },
            {
              "name": "USE_MOCK_BLOB",
              "value": "[if(equals(parameters('environmentName'), 'prod'), 'false', 'true')]"
            },
            {
              "name": "USE_MOCK_WHATSAPP",
              "value": "[if(equals(parameters('environmentName'), 'prod'), 'false', 'true')]"
            },
            {
              "name": "USE_MOCK_AUTH",
              "value": "[if(equals(parameters('environmentName'), 'prod'), 'false', 'true')]"
            },
            {
              "name": "AZURE_BLOB_CONTAINER",
              "value": "[variables('blobContainerName')]"
            },
            {
              "name": "WEBSITES_PORT",
              "value": "8000"
            },
            {
              "name": "DATABASE_URL",
              "value": "[format('@Microsoft.KeyVault(SecretUri={0})', reference(resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'database-url'), '2023-07-01').secretUriWithVersion)]"
            },
            {
              "name": "JWT_SECRET",
              "value": "[format('@Microsoft.KeyVault(SecretUri={0})', reference(resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'jwt-secret'), '2023-07-01').secretUriWithVersion)]"
            },
            {
              "name": "AZURE_BLOB_CONNECTION_STRING",
              "value": "[format('@Microsoft.KeyVault(SecretUri={0})', reference(resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'blob-connection-string'), '2023-07-01').secretUriWithVersion)]"
            },
            {
              "name": "AZURE_OPENAI_API_KEY",
              "value": "[format('@Microsoft.KeyVault(SecretUri={0})', reference(resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'openai-api-key'), '2023-07-01').secretUriWithVersion)]"
            },
            {
              "name": "WHATSAPP_VERIFY_TOKEN",
              "value": "[parameters('whatsappVerifyToken')]"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', format('appi-kuberaiq-{0}', parameters('environmentName'))), '2020-02-02').ConnectionString]"
            },
            {
              "name": "CORS_ORIGINS",
              "value": "[format('[\"https://{0}.azurewebsites.net\"]', variables('webAppName'))]"
            },
            {
              "name": "GOOGLE_CLIENT_ID",
              "value": "[parameters('googleClientId')]"
            },
            {
              "name": "GOOGLE_CLIENT_SECRET",
              "value": "[parameters('googleClientSecret')]"
            },
            {
              "name": "ENTRA_TENANT_ID",
              "value": "[parameters('entraTenantId')]"
            },
            {
              "name": "ENTRA_CLIENT_ID",
              "value": "[parameters('entraClientId')]"
            },
            {
              "name": "ENTRA_CLIENT_SECRET",
              "value": "[parameters('entraClientSecret')]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]",
        "[resourceId('Microsoft.Insights/components', format('appi-kuberaiq-{0}', parameters('environmentName')))]",
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'blob-connection-string')]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'database-url')]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'jwt-secret')]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'openai-api-key')]"
      ]
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "[format('DOCKER|{0}/kuberaiq-web:latest', reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').loginServer)]",
          "acrUseManagedIdentityCreds": true,
          "alwaysOn": "[not(equals(parameters('environmentName'), 'dev'))]",
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "appSettings": [
            {
              "name": "NEXT_PUBLIC_API_URL",
              "value": "[format('https://{0}.azurewebsites.net', variables('apiAppName'))]"
            },
            {
              "name": "NEXT_PUBLIC_USE_MOCK_AUTH",
              "value": "[if(equals(parameters('environmentName'), 'prod'), 'false', 'true')]"
            },
            {
              "name": "NEXT_PUBLIC_GOOGLE_CLIENT_ID",
              "value": "[parameters('googleClientId')]"
            },
            {
              "name": "NEXT_PUBLIC_GOOGLE_REDIRECT_URI",
              "value": "[format('https://{0}.azurewebsites.net/auth/callback', variables('webAppName'))]"
            },
            {
              "name": "NEXT_PUBLIC_ENTRA_CLIENT_ID",
              "value": "[parameters('entraClientId')]"
            },
            {
              "name": "NEXT_PUBLIC_ENTRA_TENANT_ID",
              "value": "[parameters('entraTenantId')]"
            },
            {
              "name": "NEXT_PUBLIC_ENTRA_REDIRECT_URI",
              "value": "[format('https://{0}.azurewebsites.net/auth/callback', variables('webAppName'))]"
            },
            {
              "name": "WEBSITES_PORT",
              "value": "3000"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', format('appi-kuberaiq-{0}', parameters('environmentName'))), '2020-02-02').ConnectionString]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]",
        "[resourceId('Microsoft.Insights/components', format('appi-kuberaiq-{0}', parameters('environmentName')))]",
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.KeyVault/vaults/{0}', variables('keyVaultName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), resourceId('Microsoft.Web/sites', variables('apiAppName')), 'kv-secrets-user')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445c86b69e6')]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('apiAppName')), '2023-12-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('apiAppName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.ContainerRegistry/registries/{0}', variables('acrName'))]",
      "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), resourceId('Microsoft.Web/sites', variables('apiAppName')), 'acr-pull')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '7f951dda-4ed3-4680-a7ca-43fe172d538d')]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('apiAppName')), '2023-12-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]",
        "[resourceId('Microsoft.Web/sites', variables('apiAppName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.ContainerRegistry/registries/{0}', variables('acrName'))]",
      "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), resourceId('Microsoft.Web/sites', variables('webAppName')), 'acr-pull')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '7f951dda-4ed3-4680-a7ca-43fe172d538d')]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('webAppName')), '2023-12-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]",
        "[resourceId('Microsoft.Web/sites', variables('webAppName'))]"
      ]
    }
  ],
  "outputs": {
    "apiAppName": {
      "type": "string",
      "value": "[variables('apiAppName')]"
    },
    "webAppName": {
      "type": "string",
      "value": "[variables('webAppName')]"
    },
    "apiAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', variables('apiAppName')), '2023-12-01').defaultHostName)]"
    },
    "webAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', variables('webAppName')), '2023-12-01').defaultHostName)]"
    },
    "acrLoginServer": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').loginServer]"
    },
    "acrName": {
      "type": "string",
      "value": "[variables('acrName')]"
    },
    "keyVaultUri": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), '2023-07-01').vaultUri]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "[variables('keyVaultName')]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[variables('storageAccountName')]"
    },
    "postgresServerFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('postgresServerName')), '2023-12-01-preview').fullyQualifiedDomainName]"
    },
    "appInsightsConnectionString": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/components', format('appi-kuberaiq-{0}', parameters('environmentName'))), '2020-02-02').ConnectionString]"
    }
  }
}